---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Breadcrumb from "@components/layout/Breadcrumb.astro";
import Badge from "@components/ui/Badge.astro";
import Icon from "@components/ui/Icon.astro";
import Gallery from "@components/sections/Gallery.astro";
import CTA from "@components/sections/CTA.astro";
import { formatDate } from "@/lib/utils";
import { breadcrumbSchema } from "@/lib/seo";

export async function getStaticPaths() {
  const projects = await getCollection("proyectos");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, client, location, services, technologies, coverImage, gallery, result, date } = project.data;
const { Content } = await render(project);

const description = summary;
const structuredData = [
  breadcrumbSchema([
    { label: "Proyectos", href: "/proyectos" },
    { label: title },
  ]),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData} type="article">
  <article>
    <div class="relative overflow-hidden bg-ink pb-0 pt-32 text-white lg:pt-36">
      <div class="grid-backdrop-dark pointer-events-none absolute inset-0"></div>
      <Container class="relative pb-14">
        <Breadcrumb items={[{ label: "Proyectos", href: "/proyectos" }, { label: title }]} light />
        <div class="mt-6 flex flex-wrap gap-2">
          {services.map((s) => <Badge variant="dark">{s}</Badge>)}
        </div>
        <h1 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">{title}</h1>
        <p class="mt-5 max-w-2xl text-lg text-gray-300">{summary}</p>
        <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3 font-mono text-xs uppercase tracking-wide text-gray-400">
          {client && <span class="flex items-center gap-2"><Icon name="users" class="size-4 text-orange-400" />{client}</span>}
          <span class="flex items-center gap-2"><Icon name="map-pin" class="size-4 text-orange-400" />{location}</span>
          <span class="flex items-center gap-2"><Icon name="calendar" class="size-4 text-orange-400" />{formatDate(date)}</span>
        </div>
      </Container>
      <Image src={coverImage} alt={title} width={1400} height={700} class="mt-10 w-full object-cover" />
    </div>

    <Container class="py-16 lg:py-20">
      <div class="grid grid-cols-1 gap-14 lg:grid-cols-3">
        <div class="prose prose-neutral max-w-none lg:col-span-2 prose-headings:font-display prose-headings:font-semibold prose-a:text-orange">
          <Content />
        </div>
        <aside class="space-y-8 lg:col-span-1">
          <div class="border border-gray-200 p-6">
            <p class="eyebrow">Resultado</p>
            <p class="mt-3 text-sm leading-relaxed text-gray-700">{result}</p>
          </div>
          <div class="border border-gray-200 p-6">
            <p class="eyebrow">Tecnologías utilizadas</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {technologies.map((tech) => <Badge variant="outline">{tech}</Badge>)}
            </div>
          </div>
        </aside>
      </div>

      {gallery && gallery.length > 0 && (
        <div class="mt-16">
          <p class="eyebrow mb-6">Galería</p>
          <Gallery images={gallery} alt={title} />
        </div>
      )}
    </Container>
  </article>

  <CTA
    title="¿Le gustaría un resultado similar en su empresa?"
    primaryCta={{ label: "Solicitar cotización", href: "/contacto" }}
    secondaryCta={{ label: "Ver más proyectos", href: "/proyectos" }}
  />
</BaseLayout>
