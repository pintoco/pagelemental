---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import PageHero from "@components/sections/PageHero.astro";
import ContactForm from "@components/forms/ContactForm.astro";
import Icon from "@components/ui/Icon.astro";
import { SITE } from "@/data/site";
import { breadcrumbSchema } from "@/lib/seo";

const title = "Contacto";
const description =
  "Solicite una cotización o converse con nuestro equipo técnico sobre su proyecto de CCTV, redes, fibra óptica, servidores o infraestructura tecnológica.";
const structuredData = [breadcrumbSchema([{ label: "Contacto" }])];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <PageHero
    eyebrow="Contacto"
    title="Conversemos sobre su proyecto"
    description="Complete el formulario con el mayor detalle posible. Un especialista revisará su solicitud y le responderá dentro de las próximas 24 horas hábiles."
    breadcrumbs={[{ label: "Contacto" }]}
  />

  <section class="py-16 lg:py-24">
    <Container>
      <div class="grid grid-cols-1 gap-14 lg:grid-cols-3">
        <div class="lg:col-span-1">
          <div class="space-y-8">
            <div class="flex gap-4">
              <span class="flex size-11 shrink-0 items-center justify-center rounded-sm bg-orange-50 text-orange">
                <Icon name="map-pin" class="size-5" />
              </span>
              <div>
                <p class="text-sm font-semibold text-ink">Oficina central</p>
                <p class="mt-1 text-sm text-gray-600">{SITE.address.street}<br />{SITE.address.city}, {SITE.address.region}</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex size-11 shrink-0 items-center justify-center rounded-sm bg-orange-50 text-orange">
                <Icon name="phone" class="size-5" />
              </span>
              <div>
                <p class="text-sm font-semibold text-ink">Teléfono</p>
                <a href={SITE.phoneHref} class="mt-1 block text-sm text-gray-600 hover:text-orange">{SITE.phone}</a>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex size-11 shrink-0 items-center justify-center rounded-sm bg-orange-50 text-orange">
                <Icon name="mail" class="size-5" />
              </span>
              <div>
                <p class="text-sm font-semibold text-ink">Correo</p>
                <a href={`mailto:${SITE.email}`} class="mt-1 block text-sm text-gray-600 hover:text-orange">{SITE.email}</a>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex size-11 shrink-0 items-center justify-center rounded-sm bg-orange-50 text-orange">
                <Icon name="clock" class="size-5" />
              </span>
              <div>
                <p class="text-sm font-semibold text-ink">Horario de atención</p>
                <p class="mt-1 text-sm text-gray-600">{SITE.hours}</p>
              </div>
            </div>
            <a
              href={`https://wa.me/${SITE.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 rounded-sm bg-[#25D366] px-6 py-3.5 text-sm font-medium text-white transition-transform hover:scale-[1.02]"
            >
              <Icon name="whatsapp" class="size-4" />
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <div class="border border-gray-200 bg-white p-6 sm:p-8 lg:col-span-2">
          <ContactForm />
        </div>
      </div>
    </Container>
  </section>

  <div class="h-[420px] w-full border-t border-gray-200 bg-gray-100">
    <iframe
      title="Ubicación de Elemental Pro SPA"
      class="size-full"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      src="https://www.google.com/maps?q=Atacama+860,+Copiapó,+Chile&output=embed"
    ></iframe>
  </div>
</BaseLayout>
