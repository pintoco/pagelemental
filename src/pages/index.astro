---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import Button from "@components/ui/Button.astro";
import Icon from "@components/ui/Icon.astro";
import Hero from "@components/sections/Hero.astro";
import Stats from "@components/sections/Stats.astro";
import Partners from "@components/sections/Partners.astro";
import Testimonials from "@components/sections/Testimonials.astro";
import CTA from "@components/sections/CTA.astro";
import ServiceCard from "@components/cards/ServiceCard.astro";
import ProjectCard from "@components/cards/ProjectCard.astro";
import PostCard from "@components/cards/PostCard.astro";
import { services } from "@/data/services";
import { SITE } from "@/data/site";

const featuredProjects = (await getCollection("proyectos", ({ data }) => data.featured))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const differentiators = [
  { icon: "shield", title: "Un solo proveedor responsable", description: "Diseño, instalación y mantención bajo un mismo equipo técnico, sin traspasos de responsabilidad entre proveedores." },
  { icon: "clock", title: "SLA con tiempos definidos", description: "Acuerdos de nivel de servicio claros, con tiempos de respuesta y resolución comprometidos por escrito." },
  { icon: "target", title: "Ingeniería antes que venta", description: "Cada propuesta parte de un levantamiento técnico real, no de una plantilla comercial genérica." },
  { icon: "trending-up", title: "Preparado para crecer", description: "Arquitecturas documentadas y dimensionadas para escalar junto con su operación." },
];
---

<BaseLayout title={SITE.name} description={SITE.description} heroOnDark>
  <Hero
    eyebrow="Infraestructura tecnológica para empresas e industria"
    title="Construimos la infraestructura que sostiene su operación crítica"
    description="Diseñamos, instalamos y mantenemos sistemas de CCTV, redes, fibra óptica, servidores y control de acceso para empresas, industria y organismos públicos en todo Chile."
    primaryCta={{ label: "Solicitar cotización", href: "/contacto" }}
    secondaryCta={{ label: "Ver servicios", href: "/servicios" }}
  />

  <Stats />

  <section class="py-20 lg:py-28">
    <Container>
      <div class="flex flex-col items-end justify-between gap-6 lg:flex-row">
        <SectionHeading
          eyebrow="Qué hacemos"
          title="Infraestructura tecnológica de extremo a extremo"
          description="Desde el cableado físico hasta la nube: un mismo equipo técnico responsable de que toda su infraestructura funcione."
        />
        <a href="/servicios" class="hidden shrink-0 items-center gap-2 text-sm font-medium text-orange lg:flex">
          Ver todos los servicios
          <Icon name="arrow-right" class="size-4" />
        </a>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.slice(0, 6).map((service, i) => <ServiceCard service={service} index={i} />)}
      </div>

      <a href="/servicios" class="mt-8 flex items-center justify-center gap-2 text-sm font-medium text-orange lg:hidden">
        Ver todos los servicios
        <Icon name="arrow-right" class="size-4" />
      </a>
    </Container>
  </section>

  <section class="bg-navy py-20 text-white lg:py-28">
    <Container>
      <SectionHeading
        eyebrow="Por qué Elemental Pro"
        title="Ingeniería, no solo instalación"
        light
      />
      <div class="mt-14 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {differentiators.map((item, i) => (
          <div class="animate-fade-up" style={`animation-delay:${i * 90}ms`}>
            <Icon name={item.icon} class="size-7 text-orange-400" />
            <h3 class="mt-4 text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-300">{item.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  {featuredProjects.length > 0 && (
    <section class="py-20 lg:py-28">
      <Container>
        <div class="flex flex-col items-end justify-between gap-6 lg:flex-row">
          <SectionHeading
            eyebrow="Proyectos"
            title="Casos de éxito en terreno"
            description="Instalaciones reales en centros comerciales, municipios, plantas industriales y edificios corporativos."
          />
          <a href="/proyectos" class="hidden shrink-0 items-center gap-2 text-sm font-medium text-orange lg:flex">
            Ver todos los proyectos
            <Icon name="arrow-right" class="size-4" />
          </a>
        </div>
        <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </Container>
    </section>
  )}

  <Partners />
  <Testimonials />

  {latestPosts.length > 0 && (
    <section class="py-20 lg:py-28">
      <Container>
        <SectionHeading
          eyebrow="Blog"
          title="Artículos y buenas prácticas"
          description="Contenido técnico sobre infraestructura, seguridad electrónica y redes, escrito por nuestro equipo de ingeniería."
        />
        <div class="mt-14 grid grid-cols-1 gap-6 lg:grid-cols-3">
          {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
        <div class="mt-10 flex justify-center">
          <Button href="/blog" variant="ghost">
            Ver todos los artículos
            <Icon name="arrow-right" class="size-4" />
          </Button>
        </div>
      </Container>
    </section>
  )}

  <CTA
    title="¿Tiene un proyecto de infraestructura tecnológica en mente?"
    description="Cuéntenos qué necesita y le enviaremos una propuesta técnica y comercial en menos de 48 horas hábiles."
    primaryCta={{ label: "Solicitar cotización", href: "/contacto" }}
    secondaryCta={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.whatsapp}` }}
  />
</BaseLayout>
