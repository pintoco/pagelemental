---
import Container from "@components/ui/Container.astro";
import { stats } from "@/data/marketing";
---

<section class="border-y border-gray-200 bg-gray-50">
  <Container>
    <div class="grid grid-cols-2 divide-x divide-y divide-gray-200 lg:grid-cols-4 lg:divide-y-0">
      {stats.map((stat, i) => (
        <div class="flex flex-col items-center justify-center gap-2 px-4 py-10 text-center animate-fade-up" style={`animation-delay:${i * 80}ms`}>
          <span class="font-display text-3xl font-semibold text-navy sm:text-4xl">{stat.value}</span>
          <span class="text-sm text-gray-600">{stat.label}</span>
        </div>
      ))}
    </div>
  </Container>
</section>
