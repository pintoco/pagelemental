---
import Container from "@components/ui/Container.astro";
import Breadcrumb from "@components/layout/Breadcrumb.astro";
import type { BreadcrumbItem } from "@/types";

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  breadcrumbs: BreadcrumbItem[];
}

const { eyebrow, title, description, breadcrumbs } = Astro.props;
---

<section class="relative overflow-hidden border-b border-gray-200 bg-gray-50 pb-14 pt-32 lg:pt-36">
  <div class="grid-backdrop pointer-events-none absolute inset-0 opacity-70"></div>
  <Container class="relative">
    <Breadcrumb items={breadcrumbs} />
    <p class="eyebrow mt-6">
      <span class="h-px w-6 bg-current"></span>
      {eyebrow}
    </p>
    <h1 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">{title}</h1>
    {description && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-gray-600">{description}</p>}
  </Container>
</section>
