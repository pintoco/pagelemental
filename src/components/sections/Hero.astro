---
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";
import Icon from "@components/ui/Icon.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { eyebrow, title, description, primaryCta, secondaryCta } = Astro.props;
---

<section class="relative overflow-hidden bg-ink pb-20 pt-40 text-white lg:pb-28 lg:pt-48">
  <div class="grid-backdrop-dark pointer-events-none absolute inset-0"></div>
  <div class="pointer-events-none absolute -right-40 -top-40 size-[560px] rounded-full bg-orange/20 blur-3xl"></div>
  <div class="pointer-events-none absolute -left-32 bottom-0 size-[420px] rounded-full bg-orange-400/10 blur-3xl"></div>

  <Container class="relative">
    <div class="max-w-3xl animate-fade-up">
      <p class="eyebrow text-orange-400">
        <span class="h-px w-6 bg-current"></span>
        {eyebrow}
      </p>
      <h1 class="mt-6 text-4xl font-semibold leading-[1.08] text-white sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-gray-300">
        {description}
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        {primaryCta && (
          <Button href={primaryCta.href} size="lg">
            {primaryCta.label}
            <Icon name="arrow-right" class="size-4 transition-transform group-hover:translate-x-0.5" />
          </Button>
        )}
        {secondaryCta && (
          <Button href={secondaryCta.href} size="lg" variant="outline-light">
            {secondaryCta.label}
          </Button>
        )}
      </div>
    </div>

    <div class="mt-20 flex flex-wrap items-center gap-x-10 gap-y-4 border-t border-white/10 pt-8 font-mono text-xs uppercase tracking-wide text-gray-400 animate-fade-in [animation-delay:400ms]">
      <span class="flex items-center gap-2"><Icon name="shield" class="size-4 text-orange-400" /> Certificación TIA/EIA</span>
      <span class="flex items-center gap-2"><Icon name="clock" class="size-4 text-orange-400" /> SLA con tiempos definidos</span>
      <span class="flex items-center gap-2"><Icon name="target" class="size-4 text-orange-400" /> 100+ proyectos entregados</span>
    </div>
  </Container>
</section>
