---
import Button from "@components/ui/Button.astro";
---

<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-50 hidden translate-y-full border-t border-gray-200 bg-white/95 backdrop-blur-md transition-transform duration-500"
  role="dialog"
  aria-live="polite"
  aria-label="Aviso de cookies"
>
  <div class="mx-auto flex max-w-7xl flex-col items-start gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between lg:px-10">
    <p class="text-sm text-gray-600">
      Utilizamos cookies propias y de terceros para mejorar tu experiencia y analizar el tráfico del sitio. Puedes revisar más detalles en nuestra
      <a href="/politica-privacidad" class="font-medium text-orange underline underline-offset-2">Política de Privacidad</a>.
    </p>
    <div class="flex shrink-0 items-center gap-3">
      <button id="cookie-decline" type="button" class="text-sm font-medium text-gray-500 hover:text-ink">Rechazar</button>
      <Button id="cookie-accept" size="sm">Aceptar</Button>
    </div>
  </div>
</div>

<script>
  const KEY = "elemental-pro-cookie-consent";
  const banner = document.getElementById("cookie-banner");
  const accept = document.getElementById("cookie-accept");
  const decline = document.getElementById("cookie-decline");

  function show() {
    banner?.classList.remove("hidden");
    requestAnimationFrame(() => banner?.classList.remove("translate-y-full"));
  }

  function hide(value: "accepted" | "declined") {
    localStorage.setItem(KEY, value);
    banner?.classList.add("translate-y-full");
    setTimeout(() => banner?.classList.add("hidden"), 500);
  }

  if (!localStorage.getItem(KEY)) {
    setTimeout(show, 800);
  }

  accept?.addEventListener("click", () => hide("accepted"));
  decline?.addEventListener("click", () => hide("declined"));
</script>
