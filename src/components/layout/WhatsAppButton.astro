---
import Icon from "@components/ui/Icon.astro";
import { SITE } from "@/data/site";

const message = encodeURIComponent("Hola, quisiera cotizar un proyecto con Elemental Pro.");
const href = `https://wa.me/${SITE.whatsapp}?text=${message}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribir por WhatsApp a Elemental Pro"
  class="fixed bottom-6 right-6 z-40 flex size-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-elevated transition-transform duration-300 hover:scale-105 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-400"
>
  <Icon name="whatsapp" class="size-7" strokeWidth={1.5} />
  <span class="absolute inset-0 -z-10 animate-ping rounded-full bg-[#25D366]/40" aria-hidden="true"></span>
</a>
