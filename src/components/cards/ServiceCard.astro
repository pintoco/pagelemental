---
import Icon from "@components/ui/Icon.astro";
import type { Service } from "@/types";

interface Props {
  service: Service;
  index?: number;
}

const { service, index = 0 } = Astro.props;
---

<a
  href={`/servicios/${service.slug}`}
  class="corner-frame group relative flex flex-col justify-between border border-gray-200 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-navy hover:shadow-elevated animate-fade-up"
  style={`animation-delay:${index * 60}ms`}
>
  <div>
    <div class="flex items-center justify-between">
      <span class="flex size-12 items-center justify-center rounded-sm bg-orange-50 text-orange transition-colors duration-300 group-hover:bg-navy group-hover:text-orange-400">
        <Icon name={service.icon} class="size-6" />
      </span>
      <span class="font-mono text-xs text-gray-400">{String(index + 1).padStart(2, "0")}</span>
    </div>
    <h3 class="mt-6 text-xl font-semibold text-ink">{service.name}</h3>
    <p class="mt-3 text-sm leading-relaxed text-gray-600">{service.summary}</p>
  </div>
  <div class="mt-8 flex items-center gap-2 text-sm font-medium text-orange">
    Ver servicio
    <Icon name="arrow-right" class="size-4 transition-transform duration-300 group-hover:translate-x-1" />
  </div>
</a>
