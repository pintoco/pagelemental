---
import { Image } from "astro:assets";
import Icon from "@components/ui/Icon.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"proyectos">;
}

const { project } = Astro.props;
const { title, summary, location, services, coverImage } = project.data;
---

<a href={`/proyectos/${project.slug}`} class="group relative flex flex-col overflow-hidden border border-gray-200 bg-white transition-all duration-300 hover:-translate-y-1 hover:shadow-elevated">
  <div class="relative aspect-[3/2] overflow-hidden bg-ink">
    <Image
      src={coverImage}
      alt={title}
      width={600}
      height={400}
      class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-transparent to-transparent"></div>
    <div class="absolute bottom-3 left-3 flex items-center gap-1.5 font-mono text-xs uppercase tracking-wide text-white/90">
      <Icon name="map-pin" class="size-3.5" />
      {location}
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="flex flex-wrap gap-1.5">
      {services.slice(0, 2).map((s) => (
        <span class="rounded-full bg-orange-50 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-orange">{s}</span>
      ))}
    </div>
    <h3 class="mt-3 text-lg font-semibold text-ink">{title}</h3>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-gray-600">{summary}</p>
    <div class="mt-5 flex items-center gap-2 text-sm font-medium text-orange">
      Ver caso
      <Icon name="arrow-right" class="size-4 transition-transform duration-300 group-hover:translate-x-1" />
    </div>
  </div>
</a>
